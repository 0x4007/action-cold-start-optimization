{
  "name": "github-action-plugin",
  "version": "1.0.0",
  "description": "GitHub Action for plugin execution with WebAssembly optimization",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "npm run build:wasm && npm run build:ts && npm run build:sdk",
    "build:ts": "tsc",
    "build:wasm": "cd wasm && wasm-pack build --target nodejs --out-dir ../pkg",
    "build:bundle": "node build-bundle.js",
    "build:optimized": "bun build-optimized.ts",
    "build:sdk": "tsc -p tsconfig.sdk.json",
    "test": "bun test",
    "create:plugin": "node scripts/create-plugin.js",
    "create:plugin:interactive": "bun scripts/tools/create-plugin-interactive.ts",
    "create:plugin:auto": "bun scripts/tools/create-plugin-interactive.ts -- --non-interactive",
    "dev:server": "bun scripts/tools/local-dev-server.ts",
    "generate:action": "node scripts/generate-action.js"
  },
  "keywords": [
    "github",
    "action",
    "plugin",
    "wasm",
    "webassembly",
    "sdk"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.1",
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "bun-types": "latest",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "ejs": "^3.1.10",
    "esbuild": "^0.25.1",
    "express": "^4.21.2",
    "inquirer": "^12.5.0",
    "js-yaml": "^4.1.0",
    "socket.io": "^4.8.1",
    "ts-node": "^10.9.2",
    "typescript": "latest",
    "wasm-pack": "^0.12.1"
  },
  "dependencies": {
    "puppeteer": "^24.4.0"
  }
}
